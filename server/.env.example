# Required in production: a long, random secret key for signing JWT tokens.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Comma-separated list of allowed CORS origins.
# Example: CORS_ORIGINS=https://yourapp.example.com,https://www.yourapp.example.com
# Leave as * only for local development.
CORS_ORIGINS=*

# SQLAlchemy database URL (defaults to a local SQLite file).
# Example for PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/pytter
DATABASE_URL=sqlite:///pytter.db

# Set to true to enable Flask debug mode. NEVER enable in production.
FLASK_DEBUG=false

# Port to listen on (default: 5000).
PORT=5000

# Rate limit storage backend URI.
# Defaults to in-memory (resets on restart, not suitable for multi-process deployments).
# For production with multiple workers, use Redis:
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0
RATELIMIT_STORAGE_URI=memory://
